      'إقامة العروض في غير الأوقات المنصوص عليها في التصريح',
      'إقامة عرض حي لمؤدي لم يتم اعتماده من قبل الهيئة',
      'إقامة نشاط ترفيهي يتضمن سلوك يتنافى مع الهوية العربية والإسلامية للمملكة العربية السعودية',
      'عدم الالتزام بالمظهر الاحترافي وذلك بارتداء ملابس ضيقة',
      'عدم الالتزام بالمظهر الاحترافي وذلك بارتداء ملابس شفافة',
    ]
  },
  {
    id:'cid', label:'إدارة التحريات والبحث الجنائي',
    sub:'الذوق العام والأحداث والمسكرات',
    hasCount: true,
    violations:[
      'الإخلال بالذوق العام',
      'ضبط أحداث',
      'الاشتباه بوجود مسكرات أو مواد مخدرة',
      'وجود أشخاص في حالة مخلة بالآداب العامة',
      'عدم الالتزام بقواعد الفصل بين الجنسين',
    ]
  },
  {
    id:'moci', label:'وزارة التجارة',
    sub:'التستر التجاري والسجل التجاري',
    hasCount: false,
    violations:[
      'التستر التجاري على عمالة أجنبية',
      'عدم تجديد السجل التجاري أو انتهاء صلاحيته',
      'عدم عرض السجل التجاري في مكان ظاهر للعملاء',
    ]
  }
];

function logoImg(id, size=36, forPrint=false) {
  const url = LOGOS[id] || '';
  const filter = forPrint ? 'filter:brightness(0) invert(1);' : '';
  return url
    ? `<img src="${url}" alt="" width="${size}" height="${size}" style="object-fit:contain;${filter}" onerror="this.style.display='none'">`
    : '';
}

function init() {
  const container = document.getElementById('agencies-container');
  AGENCIES.forEach(ag => {
    const block = document.createElement('div');
    block.className = 'agency-block';
    const vioRows = ag.violations.map((v,i) => `
      <div class="vio-item">
        <input type="checkbox" id="${ag.id}-${i}" onchange="onCheck('${ag.id}','${ag.id}-${i}')">
        <label class="vio-label" for="${ag.id}-${i}">${v}</label>
        ${ag.hasCount ? `
        <div class="vio-count">
          <input type="number" min="1" id="cnt-${ag.id}-${i}" value="1" disabled title="عدد المخالفات">
          <div class="count-lbl">العدد</div>
        </div>` : ''}
      </div>`).join('');

    block.innerHTML = `
      <div class="agency-header" id="hdr-${ag.id}" onclick="toggle('${ag.id}')">
        ${logoImg(ag.id, 38)}
        <div style="flex:1;min-width:0">
          <div class="agency-name">${ag.label}</div>
          <div class="agency-sub">${ag.sub}</div>
        </div>
        <span class="badge" id="bdg-${ag.id}">0 مخالفة</span>
        <span class="chevron" id="chv-${ag.id}">▼</span>
      </div>
      <div class="violations-panel" id="pnl-${ag.id}">
        ${vioRows}
        <div class="rep-field">
          <label>اسم ممثل الجهة:</label>
          <input type="text" id="rep-${ag.id}" placeholder="الاسم الكامل لممثل ${ag.label}">
        </div>
        <div class="custom-row">
          <input type="text" id="cust-${ag.id}" placeholder="أضف مخالفة مخصصة...">
          <button class="btn-add" onclick="addCustom('${ag.id}')">+ إضافة</button>
        </div>
      </div>`;
    container.appendChild(block);
  });
  document.getElementById('visit-date').value = new Date().toISOString().split('T')[0];
}

function onCheck(agId, cbId) {
  const cb = document.getElementById(cbId);
  const cntEl = document.getElementById('cnt-' + cbId);
  if (cntEl) cntEl.disabled = !cb.checked;
  countViolations(agId);
}

function toggle(id) {
  const pnl = document.getElementById('pnl-'+id);
  const hdr = document.getElementById('hdr-'+id);
  const isOpen = pnl.classList.contains('open');
  pnl.classList.toggle('open', !isOpen);
  hdr.classList.toggle('open', !isOpen);
  document.getElementById('chv-'+id).textContent = isOpen ? '▼' : '▲';
}

function countViolations(id) {
  const panel = document.getElementById('pnl-'+id);
  const count = panel.querySelectorAll('input[type=checkbox]:checked').length;
  const badge = document.getElementById('bdg-'+id);
  badge.textContent = count + ' مخالفة';
  badge.className = 'badge' + (count > 0 ? ' has-violations' : '');
}

function addCustom(agId) {
  const input = document.getElementById('cust-'+agId);
  const txt = input.value.trim();
  if (!txt) return;
  const panel = document.getElementById('pnl-'+agId);
  const customRow = panel.querySelector('.custom-row');
  const uid = agId + '-c-' + Date.now();
  const ag = AGENCIES.find(a => a.id === agId);
  const item = document.createElement('div');
  item.className = 'vio-item';
  item.innerHTML = `<input type="checkbox" id="${uid}" checked onchange="onCheck('${agId}','${uid}')">
    <label class="vio-label" for="${uid}">${txt}</label>
    ${ag && ag.hasCount ? `<div class="vio-count"><input type="number" min="1" id="cnt-${uid}" value="1"><div class="count-lbl">العدد</div></div>` : ''}`;
  panel.insertBefore(item, customRow);
  input.value = '';
  countViolations(agId);
}

function getCheckedWithCount(agId) {
  const panel = document.getElementById('pnl-'+agId);
  const ag = AGENCIES.find(a => a.id === agId);
  return [...panel.querySelectorAll('input[type=checkbox]:checked')].map(cb => {
    const label = cb.nextElementSibling.textContent;
    let cnt = null;
    if (ag && ag.hasCount) {
      const cntEl = document.getElementById('cnt-' + cb.id);
      if (cntEl) cnt = parseInt(cntEl.value) || 1;
    }
    return { label, cnt };
  });
}

function buildPreview() {
  const facility  = document.getElementById('facility').value.trim() || 'غير محدد';
  const crNum     = document.getElementById('cr-num').value.trim() || '—';
  const recNum    = document.getElementById('record-num').value.trim() || '—';
  const dateVal   = document.getElementById('visit-date').value;
  const dateStr  = dateVal ? new Date(dateVal).toLocaleDateString('ar-SA-u-nu-latn',{year:'numeric',month:'long',day:'numeric'}) : 'غير محدد';
  const district = document.getElementById('district').value.trim() || '—';
  const result   = document.getElementById('result').value;

  let totalVio = 0, agenciesWithVio = 0;
  AGENCIES.forEach(ag => {
    const items = getCheckedWithCount(ag.id);
    const sum = items.reduce((s,x) => s + (x.cnt || 1), 0);
    totalVio += sum;
    if (items.length > 0) agenciesWithVio++;
  });

  const resultClass = result.includes('إغلاق') ? 'danger' : 'warning';

  document.getElementById('summary-bar').innerHTML = `
    <div class="summary-card danger"><div class="num">${totalVio}</div><div class="lbl">إجمالي المخالفات</div></div>
    <div class="summary-card"><div class="num">${agenciesWithVio}</div><div class="lbl">جهات سجّلت مخالفات</div></div>
    <div class="summary-card ${resultClass}"><div class="num" style="font-size:16px;margin-top:6px">${result}</div><div class="lbl">نتيجة الزيارة</div></div>`;

  document.getElementById('doc-meta').innerHTML = `
    <div class="doc-meta-item"><div class="key">اسم المنشأة</div><div class="val">${facility}</div></div>
    <div class="doc-meta-item"><div class="key">السجل التجاري</div><div class="val">${crNum}</div></div>
    <div class="doc-meta-item"><div class="key">تاريخ الزيارة</div><div class="val">${dateStr}</div></div>
    <div class="doc-meta-item"><div class="key">رقم المحضر</div><div class="val">${recNum}</div></div>
    <div class="doc-meta-item"><div class="key">الحي</div><div class="val">${district}</div></div>
    <div class="doc-meta-item full"><div class="key">نتيجة الزيارة</div><div class="val"><span class="result-badge ${resultClass}">${result}</span></div></div>`;

  document.getElementById('total-box').innerHTML = `
    <div class="big">${totalVio}</div>
    <div class="lbl">إجمالي المخالفات المرصودة خلال هذه الزيارة</div>`;

  let agHtml = '';
  AGENCIES.forEach(ag => {
    const items = getCheckedWithCount(ag.id);
    const agSum = items.reduce((s,x) => s + (x.cnt || 1), 0);
    let bodyHtml = '';
    if (items.length) {
      bodyHtml = `<table>${items.map((x,i) => `
        <tr>
          <td class="td-num">${i+1}</td>
          <td>${x.label}</td>
          ${x.cnt !== null ? `<td class="td-count">${x.cnt} مخالفة</td>` : ''}
        </tr>`).join('')}</table>`;
    } else {
      bodyHtml = `<p class="empty">لا توجد مخالفات مرصودة من هذه الجهة</p>`;
    }
    const repName = (document.getElementById('rep-'+ag.id)||{}).value || '';
    agHtml += `<div class="doc-agency">
      <div class="doc-agency-header">
        ${logoImg(ag.id, 28, true)}
        <span class="name">${ag.label}</span>
        <span class="count">${agSum > 0 ? agSum + ' مخالفة' : 'لا مخالفات'}</span>
      </div>
      <div class="doc-agency-body">
        ${bodyHtml}
        <div class="agency-sig-row">
          <div class="agency-sig">
            <div class="sig-name">${repName || '................................'}</div>
            <div class="sig-title">اسم ممثل الجهة</div>
            <div class="sig-line"></div>
          </div>
          <div class="agency-sig">
            <div class="sig-title" style="margin-bottom:1.5rem">التوقيع</div>
            <div class="sig-line"></div>
          </div>
        </div>
      </div>
    </div>`;
  });
  document.getElementById('doc-agencies').innerHTML = agHtml;



  ['step-1','step-2'].forEach(s => document.getElementById(s).classList.remove('active'));
  document.getElementById('step-3').classList.add('active');
  document.getElementById('form-section').style.display = 'none';
  document.getElementById('preview-section').style.display = 'block';
  window.scrollTo({top:0, behavior:'smooth'});
}

function backToForm() {
  document.getElementById('form-section').style.display = 'block';
  document.getElementById('preview-section').style.display = 'none';
  document.getElementById('step-1').classList.add('active');
  document.getElementById('step-3').classList.remove('active');
  window.scrollTo({top:0, behavior:'smooth'});
}

function resetForm() {
  if (!confirm('هل أنت متأكد من مسح جميع البيانات؟')) return;
  ['facility','cr-num','record-num','district'].forEach(id => { const el=document.getElementById(id); if(el) el.value=''; });
  AGENCIES.forEach(ag => { const r=document.getElementById('rep-'+ag.id); if(r) r.value=''; });
  document.getElementById('visit-date').value = new Date().toISOString().split('T')[0];
  document.getElementById('result').value = 'تحرير مخالفات';
  document.querySelectorAll('input[type=checkbox]').forEach(c => { c.checked = false; });
  document.querySelectorAll('.vio-count input[type=number]').forEach(n => n.disabled = true);
  AGENCIES.forEach(ag => countViolations(ag.id));
}

init();
</script>
</body>
