<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>محضر نتائج الزيارة الرقابية — اللونجات والمقاهي</title>
<style>
  :root {
    --primary: #1a4f7a;
    --primary-light: #e8f0f8;
    --primary-mid: #2d6da3;
    --danger: #c0392b;
    --danger-light: #fdf0ef;
    --success: #1e7e4e;
    --success-light: #eaf6ef;
    --warning: #b7660a;
    --warning-light: #fef6ea;
    --gray-50: #f8f8f7;
    --gray-100: #eeede9;
    --gray-200: #d5d4ce;
    --gray-400: #9a9890;
    --gray-700: #3f3e3b;
    --gray-900: #1c1b19;
    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 14px;
    --border: 0.5px solid var(--gray-200);
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.07);
    --shadow-md: 0 4px 16px rgba(0,0,0,0.09);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI','Helvetica Neue',Arial,sans-serif; background: var(--gray-50); color: var(--gray-900); min-height: 100vh; font-size: 15px; line-height: 1.6; }

  /* Header */
  .site-header { background: var(--primary); color: #fff; padding: 1rem 2rem; display: flex; align-items: center; gap: 1rem; border-bottom: 3px solid #c9a227; }
  .site-header img { width: 52px; height: 52px; object-fit: contain; filter: brightness(0) invert(1); flex-shrink: 0; }
  .site-header h1 { font-size: 17px; font-weight: 600; }
  .site-header p  { font-size: 12px; opacity: .75; margin-top: 2px; }

  .container { max-width: 920px; margin: 0 auto; padding: 2rem 1.5rem; }

  /* Steps */
  .steps { display: flex; margin-bottom: 2rem; background: #fff; border: var(--border); border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-sm); }
  .step { flex: 1; padding: .75rem 1rem; text-align: center; font-size: 13px; color: var(--gray-400); border-left: var(--border); }
  .step:last-child { border-left: none; }
  .step.active { background: var(--primary-light); color: var(--primary); font-weight: 600; }
  .step .num { display: inline-block; width: 22px; height: 22px; border-radius: 50%; background: var(--gray-200); color: var(--gray-700); font-size: 12px; line-height: 22px; text-align: center; margin-left: 6px; }
  .step.active .num { background: var(--primary); color: #fff; }

  /* Cards */
  .card { background: #fff; border: var(--border); border-radius: var(--radius-lg); padding: 1.5rem; margin-bottom: 1.25rem; box-shadow: var(--shadow-sm); }
  .card-title { font-size: 15px; font-weight: 600; color: var(--primary); margin-bottom: 1.25rem; padding-bottom: .6rem; border-bottom: 1.5px solid var(--primary-light); display: flex; align-items: center; gap: .5rem; }

  /* Form */
  .field-grid { display: grid; gap: 1rem; }
  .field-grid.two   { grid-template-columns: 1fr 1fr; }
  .field-grid.three { grid-template-columns: 1fr 1fr 1fr; }
  .field-grid.four  { grid-template-columns: 1fr 1fr 1fr 1fr; }
  .field { display: flex; flex-direction: column; gap: 5px; }
  label { font-size: 12px; color: var(--gray-400); font-weight: 500; }
  input[type=text], input[type=date], input[type=number], select, textarea {
    width: 100%; padding: 9px 12px; border: var(--border); border-radius: var(--radius-sm);
    font-family: inherit; font-size: 14px; color: var(--gray-900); background: #fff;
    transition: border-color .15s; direction: rtl;
  }
  input:focus, select:focus, textarea:focus { outline: none; border-color: var(--primary-mid); box-shadow: 0 0 0 3px rgba(26,79,122,.1); }

  /* Agency blocks */
  .agency-block { margin-bottom: .75rem; }
  .agency-header { display: flex; align-items: center; gap: .75rem; padding: .75rem 1.1rem; background: #fff; border: var(--border); border-radius: var(--radius-md); cursor: pointer; transition: background .15s; user-select: none; }
  .agency-header:hover { background: var(--gray-50); border-color: var(--gray-400); }
  .agency-logo { width: 38px; height: 38px; object-fit: contain; flex-shrink: 0; border-radius: 4px; }
  .agency-name { font-size: 14px; font-weight: 600; flex: 1; }
  .agency-sub  { font-size: 11px; color: var(--gray-400); }
  .badge { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; background: var(--gray-100); color: var(--gray-700); white-space: nowrap; }
  .badge.has-violations { background: var(--danger-light); color: var(--danger); }
  .chevron { transition: transform .2s; color: var(--gray-400); font-size: 12px; flex-shrink: 0; }
  .agency-header.open { border-bottom-left-radius: 0; border-bottom-right-radius: 0; border-color: var(--primary-mid); }
  .agency-header.open .chevron { transform: rotate(180deg); }

  .violations-panel { display: none; padding: 1rem 1.1rem; border: var(--border); border-top: none; border-radius: 0 0 var(--radius-md) var(--radius-md); background: var(--gray-50); border-color: var(--primary-mid); }
  .violations-panel.open { display: block; }

  /* Violation item with count */
  .vio-item { display: flex; align-items: center; gap: 8px; padding: 6px 0; border-bottom: var(--border); }
  .vio-item:last-of-type { border-bottom: none; }
  .vio-item input[type=checkbox] { width: 16px; height: 16px; cursor: pointer; accent-color: var(--primary); flex-shrink: 0; }
  .vio-label { font-size: 13px; cursor: pointer; line-height: 1.5; flex: 1; }
  .vio-count { width: 60px; flex-shrink: 0; }
  .vio-count input[type=number] {
    width: 60px; padding: 4px 6px; font-size: 12px; text-align: center;
    border: var(--border); border-radius: var(--radius-sm);
    background: #fff; color: var(--gray-900);
  }
  .vio-count input[type=number]:disabled { background: var(--gray-100); color: var(--gray-400); cursor: not-allowed; }
  .count-lbl { font-size: 10px; color: var(--gray-400); text-align: center; margin-top: 2px; }

  .custom-row { display: flex; gap: 8px; margin-top: .85rem; padding-top: .75rem; border-top: var(--border); }
  .custom-row input[type=text] { flex: 1; }
  .btn-add { padding: 8px 14px; white-space: nowrap; background: #fff; border: var(--border); border-radius: var(--radius-sm); font-size: 13px; cursor: pointer; color: var(--primary); font-weight: 500; transition: background .15s; }
  .btn-add:hover { background: var(--primary-light); }

  /* Actions */
  .actions { display: flex; gap: 1rem; margin-top: 1.5rem; }
  .btn-primary { flex: 1; padding: 13px; border: none; border-radius: var(--radius-md); background: var(--primary); color: #fff; font-size: 15px; font-weight: 600; cursor: pointer; transition: background .15s; }
  .btn-primary:hover { background: var(--primary-mid); }
  .btn-ghost { padding: 13px 20px; border: var(--border); border-radius: var(--radius-md); background: #fff; color: var(--gray-700); font-size: 14px; cursor: pointer; transition: background .15s; }
  .btn-ghost:hover { background: var(--gray-100); }

  /* Summary bar */
  .summary-bar { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; margin-bottom: 1.5rem; }
  .summary-card { background: #fff; border: var(--border); border-radius: var(--radius-md); padding: 1rem; text-align: center; }
  .summary-card .num { font-size: 28px; font-weight: 700; color: var(--primary); }
  .summary-card .lbl { font-size: 11px; color: var(--gray-400); margin-top: 2px; }
  .summary-card.danger .num { color: var(--danger); }
  .summary-card.success .num { color: var(--success); }

  /* Preview / Print */
  #preview-section { display: none; }
  .print-doc { background: #fff; border: var(--border); border-radius: var(--radius-lg); padding: 2.5rem; box-shadow: var(--shadow-md); }

  /* Doc header — GEA branded */
  .doc-header { text-align: center; margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 2px solid var(--primary); }
  .doc-header-logos { display: flex; align-items: center; justify-content: center; gap: 2rem; margin-bottom: 1rem; }
  .doc-header-logos img { height: 70px; object-fit: contain; }
  .doc-header .kingdom { font-size: 12px; color: var(--gray-400); margin-bottom: .3rem; }
  .doc-header .title { font-size: 20px; font-weight: 700; color: var(--primary); margin-bottom: .2rem; }
  .doc-header .subtitle { font-size: 13px; color: var(--gray-400); }
  .doc-header .divider { display: none; }

  .doc-meta { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; margin-bottom: 1.75rem; padding: 1.25rem; background: var(--gray-50); border: var(--border); border-radius: var(--radius-md); }
  .doc-meta-item .key { font-size: 11px; color: var(--gray-400); font-weight: 500; }
  .doc-meta-item .val { font-size: 14px; font-weight: 600; color: var(--gray-900); margin-top: 2px; }
  .doc-meta-item.full { grid-column: 1/-1; }

  .result-badge { display: inline-block; padding: 4px 14px; border-radius: 20px; font-size: 13px; font-weight: 600; }
  .result-badge.danger  { background: var(--danger-light);  color: var(--danger);  }
  .result-badge.success { background: var(--success-light); color: var(--success); }
  .result-badge.warning { background: var(--warning-light); color: var(--warning); }

  .total-box { background: var(--primary-light); border: 1.5px solid var(--primary); border-radius: var(--radius-md); padding: .85rem 1.25rem; margin-bottom: 1.75rem; display: flex; align-items: center; gap: 1rem; }
  .total-box .big { font-size: 28px; font-weight: 700; color: var(--primary); }
  .total-box .lbl { font-size: 13px; color: var(--primary-mid); }

  .doc-agency { margin-bottom: 1.25rem; }
  .doc-agency-header { display: flex; align-items: center; gap: .75rem; padding: .6rem 1rem; border-radius: var(--radius-sm) var(--radius-sm) 0 0; background: var(--primary); color: #fff; }
  .doc-agency-header img { width: 28px; height: 28px; object-fit: contain; filter: brightness(0) invert(1); flex-shrink: 0; }
  .doc-agency-header .name { font-size: 14px; font-weight: 600; flex: 1; }
  .doc-agency-header .count { font-size: 12px; opacity: .8; }
  .doc-agency-body { padding: .85rem 1rem; border: 1.5px solid var(--gray-200); border-top: none; border-radius: 0 0 var(--radius-sm) var(--radius-sm); }
  .doc-agency-body table { width: 100%; border-collapse: collapse; }
  .doc-agency-body td { font-size: 13px; line-height: 1.8; color: var(--gray-700); padding: 3px 6px; }
  .doc-agency-body td.td-num { width: 40px; text-align: center; font-weight: 600; color: var(--primary); border-left: var(--border); }
  .doc-agency-body td.td-count { width: 70px; text-align: center; color: var(--danger); font-weight: 600; font-size: 12px; border-right: var(--border); }
  .doc-agency-body tr { border-bottom: var(--border); }
  .doc-agency-body tr:last-child { border-bottom: none; }
  .doc-agency-body .empty { font-size: 13px; color: var(--gray-400); font-style: italic; }

  .signatures { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--gray-200); }
  .sig { text-align: center; }
  .sig .sig-line { border-top: 1px solid var(--gray-900); margin: 2.5rem auto 0; width: 80%; }
  .sig .sig-label { font-size: 12px; color: var(--gray-400); margin-top: .4rem; }

  .print-actions { display: flex; gap: 1rem; margin-top: 1.25rem; }

  /* خانة ممثل الجهة في النموذج */
  .rep-field { margin-top:.75rem; padding-top:.75rem; border-top: var(--border); display:flex; align-items:center; gap:8px; }
  .rep-field label { font-size:12px; color:var(--gray-400); white-space:nowrap; flex-shrink:0; }
  .rep-field input { flex:1; padding:7px 10px; border:var(--border); border-radius:var(--radius-sm); font-size:13px; }

  /* توقيع الجهة في المحضر */
  .agency-sig-row { display:grid; grid-template-columns:1fr 1fr; gap:2rem; margin-top:1.25rem; padding-top:1rem; border-top: var(--border); }
  .agency-sig { text-align:center; }
  .agency-sig .sig-name { font-size:13px; font-weight:600; color:var(--gray-700); margin-bottom:.25rem; }
  .agency-sig .sig-title { font-size:11px; color:var(--gray-400); margin-bottom:1.5rem; }
  .agency-sig .sig-line { border-top:1px solid var(--gray-700); width:80%; margin:0 auto; }

  @media print {
    body { background: #fff; }
    .site-header, #form-section, .print-actions, .steps, .summary-bar { display: none !important; }
    #preview-section { display: block !important; }
    .container { padding: 0; max-width: 100%; }
    .print-doc { box-shadow: none; border: none; padding: .5rem; }
    @page { margin: 1.5cm; size: A4; }
  }

  @media (max-width: 640px) {
    .field-grid.two, .field-grid.three, .field-grid.four { grid-template-columns: 1fr; }
    .summary-bar { grid-template-columns: 1fr; }
    .doc-meta { grid-template-columns: 1fr; }
    .signatures { grid-template-columns: 1fr; }
    .site-header { padding: 1rem; }
  }
</style>
</head>
<body>

<header class="site-header">
  <img src="data:image/svg+xml;base64,"
       alt="شعار الهيئة العامة للترفيه"
       onerror="this.style.display='none'">
  <div>
    <h1>محضر نتائج الزيارة الرقابية</h1>
    <p>الهيئة العامة للترفيه — اللجنة الدائمة لمعالجة مخالفات الأنشطة الترفيهية — اللونجات والمقاهي</p>
  </div>
</header>

<div class="container">

  <div class="steps" id="steps-bar">
    <div class="step active" id="step-1"><span class="num">1</span> بيانات الزيارة</div>
    <div class="step" id="step-2"><span class="num">2</span> المخالفات</div>
    <div class="step" id="step-3"><span class="num">3</span> معاينة وتصدير</div>
  </div>

  <!-- FORM -->
  <div id="form-section">

    <div class="card">
      <div class="card-title">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        بيانات الزيارة
      </div>
      <div class="field-grid three">
        <div class="field"><label>اسم المنشأة *</label><input type="text" id="facility" placeholder="مثال: لاونج الربوة"></div>
        <div class="field"><label>السجل التجاري</label><input type="text" id="cr-num" placeholder="مثال: 1010xxxxxx"></div>
        <div class="field"><label>تاريخ الزيارة *</label><input type="date" id="visit-date"></div>
      </div>
      <div class="field-grid two" style="margin-top:1rem">
        <div class="field"><label>رقم المحضر</label><input type="text" id="record-num" placeholder="مثال: 2026/05/001"></div>
        <div class="field"></div>
      </div>
      <div class="field-grid two" style="margin-top:1rem">
        <div class="field"><label>الحي</label><input type="text" id="district" placeholder="مثال: حي العليا"></div>
        <div class="field"><label>نتيجة الزيارة *</label>
          <select id="result">
            <option value="المنشأة لا تستوجب الإغلاق أو إيقاف النشاط">المنشأة لا تستوجب الإغلاق أو إيقاف النشاط</option>
            <option value="إغلاق المنشأة">إغلاق المنشأة</option>
            <option value="إيقاف النشاط">إيقاف النشاط</option>
          </select>
        </div>
      </div>

    </div>

    <div class="card">
      <div class="card-title">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
        المخالفات حسب الجهة الحكومية
        <span style="font-size:11px;color:var(--gray-400);font-weight:400;margin-right:auto">✓ اختر المخالفة ثم أدخل عددها</span>
      </div>
      <div id="agencies-container"></div>
    </div>

    <div class="actions">
      <button class="btn-primary" onclick="buildPreview()">معاينة المحضر ←</button>
      <button class="btn-ghost" onclick="resetForm()">↺ مسح الكل</button>
    </div>

  </div>

  <!-- PREVIEW -->
  <div id="preview-section">
    <div class="summary-bar" id="summary-bar"></div>

    <div class="print-doc" id="print-doc">

      <!-- رأس المحضر بشعار الهيئة العامة للترفيه -->
      <div class="doc-header">
        <div class="doc-header-logos">
          <img src="data:image/jpeg;base64," alt="الهيئة العامة للترفيه" onerror="this.style.display='none'">
        </div>
        <p class="kingdom">المملكة العربية السعودية</p>
        <h1 class="title">الهيئة العامة للترفيه</h1>
        <h2 style="font-size:16px;font-weight:600;color:var(--gray-700);margin-top:.75rem">محضر نتائج الزيارة الميدانية</h2>
        <p class="subtitle">اللجنة الدائمة لمعالجة مخالفات الأنشطة الترفيهية</p>
      </div>

      <div class="doc-meta" id="doc-meta"></div>
      <div class="total-box" id="total-box"></div>
      <div id="doc-agencies"></div>
      </div>
    </div>

    <div class="print-actions">
      <button class="btn-primary" onclick="window.print()">🖨 طباعة / حفظ PDF</button>
      <button class="btn-ghost" onclick="backToForm()">← تعديل المحضر</button>
    </div>
  </div>

</div>

